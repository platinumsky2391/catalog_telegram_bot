# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# TELEGRAM_BOT_TOKEN: The token received from @BotFather in Telegram.
# Used by the backend server to launch the Telegram bot.
TELEGRAM_BOT_TOKEN="MY_TELEGRAM_BOT_TOKEN"

# ADMIN_CHANNEL_ID: ID of the private admin channel (e.g. -1001234567890)
# Used to send notifications when new users join the bot.
ADMIN_CHANNEL_ID=""

# MySQL Database connection parameters for saving users
# Enter your Beget database credentials here
DB_HOST=""
DB_USER=""
DB_PASSWORD=""
DB_NAME=""
